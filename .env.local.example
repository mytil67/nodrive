# Copier ce fichier en .env.local et remplir les valeurs.
# NE PAS commiter .env.local (déjà dans .gitignore).

# Obtenu automatiquement via : vercel env pull .env.local
# Ou manuellement depuis : Vercel Dashboard → votre projet → Storage → Blob → Manage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Limites (optionnelles, valeurs par défaut utilisées si absentes)
MAX_FILE_SIZE_MB=4
EXPIRATION_HOURS=24
MAX_DOWNLOADS=1

# Protège le endpoint /api/cron/cleanup (valeur libre, garder secrète)
CRON_SECRET=remplacer_par_une_chaine_aleatoire_longue

# Variables exposées au frontend Vite (préfixe VITE_ obligatoire)
VITE_MAX_FILE_SIZE_MB=4
VITE_EXPIRATION_HOURS=24
